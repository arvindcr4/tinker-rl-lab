\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces \textbf  {Policy drift proxy analysis.} (a)~Stability Index vs.\ last-10 reward ($r = -0.436$, $p = 0.020$); higher instability predicts worse outcomes. (b)~Peak-to-Tail Drift with risk zones: green (stable, $\leq 0.1$), yellow (moderate), red (high, $> 0.3$). (c)~Rolling variance for Nemotron-120B (collapse) vs.\ DeepSeek-V3.1 (stable). (d)~GRPO exhibits significantly lower drift than classic-RL PPO ($p = 0.018$).}}{20}{figure.caption.62}\protected@file@percent }
\newlabel{fig:kl_proxy}{{13}{20}{\textbf {Policy drift proxy analysis.} (a)~Stability Index vs.\ last-10 reward ($r = -0.436$, $p = 0.020$); higher instability predicts worse outcomes. (b)~Peak-to-Tail Drift with risk zones: green (stable, $\leq 0.1$), yellow (moderate), red (high, $> 0.3$). (c)~Rolling variance for Nemotron-120B (collapse) vs.\ DeepSeek-V3.1 (stable). (d)~GRPO exhibits significantly lower drift than classic-RL PPO ($p = 0.018$)}{figure.caption.62}{}}
