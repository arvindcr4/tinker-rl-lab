\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Step-level reward comparison between GRPO (Tinker) and PPO (Modal H100) on Qwen3-8B GSM8K. Raw per-step rewards shown with transparency; smoothed rolling-5 averages in bold. The shaded region marks the last-10 evaluation window. GRPO achieves a higher last-10 average (34.4\%) vs.~PPO (22.5\%) despite PPO reaching a higher peak (75\% vs.~62.5\%). PPO exhibits substantially higher volatility (std 0.284 vs.~0.147).}}{18}{figure.caption.53}\protected@file@percent }
\newlabel{fig:ppo_vs_grpo}{{11}{18}{Step-level reward comparison between GRPO (Tinker) and PPO (Modal H100) on Qwen3-8B GSM8K. Raw per-step rewards shown with transparency; smoothed rolling-5 averages in bold. The shaded region marks the last-10 evaluation window. GRPO achieves a higher last-10 average (34.4\%) vs.~PPO (22.5\%) despite PPO reaching a higher peak (75\% vs.~62.5\%). PPO exhibits substantially higher volatility (std 0.284 vs.~0.147)}{figure.caption.53}{}}
\@writefile{lot}{\contentsline {table}{\numberline {15}{\ignorespaces Effect sizes, statistical power, and multiple-comparison corrections for all pairwise comparisons in this paper. Cohen's $d$ uses pooled standard deviation; $^*$ Bonferroni-significant ($\alpha /k$); $^\dag  $ Benjamini--Hochberg FDR significant (BH-FDR $< 0.05$). Post-hoc power computed at observed $d$ with $\alpha =0.05$ (two-tailed). MDE: minimum detectable effect at 80\% power.}}{18}{table.caption.54}\protected@file@percent }
\newlabel{tab:effect_sizes}{{15}{18}{Effect sizes, statistical power, and multiple-comparison corrections for all pairwise comparisons in this paper. Cohen's $d$ uses pooled standard deviation; $^*$ Bonferroni-significant ($\alpha /k$); $^\dag $ Benjamini--Hochberg FDR significant (BH-FDR $< 0.05$). Post-hoc power computed at observed $d$ with $\alpha =0.05$ (two-tailed). MDE: minimum detectable effect at 80\% power}{table.caption.54}{}}
