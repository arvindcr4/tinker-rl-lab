% neurips_2025.sty - Style file for NeurIPS 2025/2026 submissions
% Based on the standard NeurIPS style (compatible with 2024+)
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2025}[2025/01/01 NeurIPS 2025 submission style]

\newif\if@final\@finalfalse
\newif\if@preprint\@preprintfalse
\newif\if@nonatbib\@nonatbibfalse
\DeclareOption{final}{\@finaltrue}
\DeclareOption{preprint}{\@preprinttrue}
\DeclareOption{nonatbib}{\@nonatbibtrue}
\ProcessOptions\relax

% Page layout
\RequirePackage[verbose=true,letterpaper]{geometry}
\AtBeginDocument{
  \newgeometry{
    textheight=9in,
    textwidth=5.5in,
    top=1in,
    headheight=12pt,
    headsep=25pt,
    footskip=30pt
  }
}

% Fonts
\RequirePackage{times}
\RequirePackage[T1]{fontenc}

% Natbib
\if@nonatbib\else
  \RequirePackage[numbers]{natbib}
\fi

% Title formatting
\RequirePackage{fancyhdr}
\fancypagestyle{firstpage}{
  \fancyhf{}
  \if@final
    \fancyhead[C]{\small Advances in Neural Information Processing Systems (NeurIPS 2025/2026)}
  \else\if@preprint
    \fancyhead[C]{\small Preprint. Under review.}
  \else
    \fancyhead[C]{\small Submitted to NeurIPS 2026. Do not distribute.}
  \fi\fi
  \fancyfoot[C]{\thepage}
  \renewcommand{\headrulewidth}{0pt}
}
\pagestyle{fancy}
\fancyhf{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}

% Anonymization
\if@final\else\if@preprint\else
  \RequirePackage{microtype}
\fi\fi

% Section formatting
\RequirePackage[compact]{titlesec}

% Abstract
\renewenvironment{abstract}{
  \centerline{\large\bfseries Abstract}
  \vspace{0.5ex}
  \begin{quote}
}{
  \par
  \end{quote}
  \vspace{1ex}
}
