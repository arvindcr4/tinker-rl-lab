\@writefile{lof}{\contentsline {figure}{\numberline {4.3}{\ignorespaces Performance gap between GPT-4 and humans on agentic benchmarks. \textbf  {SWE-bench} tests code repair on real GitHub issues; \textbf  {WebArena} checks web navigation (booking, shopping); \textbf  {OSWorld} evaluates desktop automation requiring vision and control. The large gap (GPT-4 at 1.7--14.4\% vs. humans at 35--78\%) shows how hard autonomous multi-step execution is and motivates RL-based fine-tuning.}}{58}{figure.caption.99}\protected@file@percent }
\newlabel{fig:benchmark_comparison}{{4.3}{58}{Performance gap between GPT-4 and humans on agentic benchmarks. \textbf {SWE-bench} tests code repair on real GitHub issues; \textbf {WebArena} checks web navigation (booking, shopping); \textbf {OSWorld} evaluates desktop automation requiring vision and control. The large gap (GPT-4 at 1.7--14.4\% vs. humans at 35--78\%) shows how hard autonomous multi-step execution is and motivates RL-based fine-tuning}{figure.caption.99}{}}
