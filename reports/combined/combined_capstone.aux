\@writefile{lof}{\contentsline {figure}{\numberline {4.4}{\ignorespaces Training method comparison across agentic benchmarks (December 2025). Each benchmark shows three approaches: \textbf  {Baseline} (prompting-only methods), \textbf  {SFT} (supervised fine-tuning on demonstrations), and \textbf  {RL} (reinforcement learning with GRPO or PPO). The trend is consistent: RL-based approaches are associated with substantial gains across all benchmarks, with AIME 2024 showing the most dramatic improvement (9.3\% $\rightarrow $ 79.8\%, an 8.6$\times $ increase via DeepSeek-R1's GRPO training).}}{59}{figure.caption.101}\protected@file@percent }
\newlabel{fig:training-method-comparison}{{4.4}{59}{Training method comparison across agentic benchmarks (December 2025). Each benchmark shows three approaches: \textbf {Baseline} (prompting-only methods), \textbf {SFT} (supervised fine-tuning on demonstrations), and \textbf {RL} (reinforcement learning with GRPO or PPO). The trend is consistent: RL-based approaches are associated with substantial gains across all benchmarks, with AIME 2024 showing the most dramatic improvement (9.3\% $\rightarrow $ 79.8\%, an 8.6$\times $ increase via DeepSeek-R1's GRPO training)}{figure.caption.101}{}}
