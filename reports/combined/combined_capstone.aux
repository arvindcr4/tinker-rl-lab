\@writefile{lof}{\contentsline {figure}{\numberline {3.1}{\ignorespaces Three-stage training for agentic systems. \textbf  {Stage 1:} A base model supplies language understanding. \textbf  {Stage 2:} Imitation learning on 5K--10K examples drills task formats. \textbf  {Stage 3:} RL tunes the policy through environment interaction, letting agents cope with novel situations outside their training distribution.}}{34}{figure.caption.82}\protected@file@percent }
\newlabel{fig:rl_pipeline}{{3.1}{34}{Three-stage training for agentic systems. \textbf {Stage 1:} A base model supplies language understanding. \textbf {Stage 2:} Imitation learning on 5K--10K examples drills task formats. \textbf {Stage 3:} RL tunes the policy through environment interaction, letting agents cope with novel situations outside their training distribution}{figure.caption.82}{}}
\BKM@entry{id=76,dest={73656374696F6E2E332E32},srcline={1815}}{}
\@writefile{lof}{\contentsline {figure}{\numberline {3.2}{\ignorespaces The reinforcement learning loop. At each timestep, the \textbf  {agent} observes state $s_t$, selects action $a_t$ according to policy $\pi _\theta $, and receives reward $r_t$ from the \textbf  {environment}. We want a policy that racks up as much long-run reward as possible. In the agentic setting, the ``environment'' spans web browsers, code interpreters, operating systems, and API back-ends.}}{35}{figure.caption.83}\protected@file@percent }
\newlabel{fig:rl_loop}{{3.2}{35}{The reinforcement learning loop. At each timestep, the \textbf {agent} observes state $s_t$, selects action $a_t$ according to policy $\pi _\theta $, and receives reward $r_t$ from the \textbf {environment}. We want a policy that racks up as much long-run reward as possible. In the agentic setting, the ``environment'' spans web browsers, code interpreters, operating systems, and API back-ends}{figure.caption.83}{}}
