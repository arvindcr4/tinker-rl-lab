\@writefile{lof}{\contentsline {figure}{\numberline {4.2}{\ignorespaces Cross-attention mechanism in vision-language agents. \textbf  {Left:} The visual module converts image patches into embeddings $\mathbf  {v}_i$. \textbf  {Right:} The text module converts tokens into embeddings $\mathbf  {t}_i$. \textbf  {Center:} Cross-attention uses text as queries (Q) and visual features as keys/values (K, V), enabling the model to locate the visual region corresponding to ``search button.'' This architecture underlies GUI automation systems like CogAgent~\cite  {hong2023cogagent} and SeeClick~\cite  {cheng2024seeclick}, achieving 89--96\% grounding accuracy.}}{57}{figure.caption.98}\protected@file@percent }
\newlabel{fig:cross-attention-mechanism}{{4.2}{57}{Cross-attention mechanism in vision-language agents. \textbf {Left:} The visual module converts image patches into embeddings $\mathbf {v}_i$. \textbf {Right:} The text module converts tokens into embeddings $\mathbf {t}_i$. \textbf {Center:} Cross-attention uses text as queries (Q) and visual features as keys/values (K, V), enabling the model to locate the visual region corresponding to ``search button.'' This architecture underlies GUI automation systems like CogAgent~\cite {hong2023cogagent} and SeeClick~\cite {cheng2024seeclick}, achieving 89--96\% grounding accuracy}{figure.caption.98}{}}
