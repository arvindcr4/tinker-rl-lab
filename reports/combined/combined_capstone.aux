\@writefile{lof}{\contentsline {figure}{\numberline {5.2}{\ignorespaces Decentralized multi-agent architecture showing independent agents (1-4) coordinating through message passing (dashed lines) while interacting with a shared environment. Each agent operates independently while coordinating through messages. All agents interact with a shared environment, so multiple workers can run side-by-side and specialize (e.g., Agent 1: planning, Agent 2: coding, Agent 3: testing). Spreading out the control logic avoids bottlenecks and lets coordination patterns emerge organically.}}{66}{figure.caption.106}\protected@file@percent }
\newlabel{fig:multi_agent}{{5.2}{66}{Decentralized multi-agent architecture showing independent agents (1-4) coordinating through message passing (dashed lines) while interacting with a shared environment. Each agent operates independently while coordinating through messages. All agents interact with a shared environment, so multiple workers can run side-by-side and specialize (e.g., Agent 1: planning, Agent 2: coding, Agent 3: testing). Spreading out the control logic avoids bottlenecks and lets coordination patterns emerge organically}{figure.caption.106}{}}
