\@writefile{loa}{\contentsline {algocf}{\numberline {2}{\ignorespaces Group Relative Policy Optimization (GRPO). Unlike PPO, GRPO normalizes advantages within each group of completions, \textbf  {eliminating the need for a separate value/critic network}. A reward signal $r(\cdot )$ is still required---this can be verifiable/programmatic or from a learned reward model.}}{52}{algocf.2}\protected@file@percent }
