\@writefile{lof}{\contentsline {figure}{\numberline {3.3}{\ignorespaces Taxonomy of 19 RL research categories organized into five clusters: \textbf  {Core Algorithms} (policy/value/model-based methods), \textbf  {Learning Paradigms} (how agents acquire behavior), \textbf  {Advanced Methods} (multi-agent, hierarchical, safe exploration), \textbf  {Applications} (domain-specific implementations), and \textbf  {Infrastructure} (frameworks, benchmarks, surveys). Arrows indicate foundational dependencies.}}{38}{figure.caption.84}\protected@file@percent }
\newlabel{fig:rl_taxonomy}{{3.3}{38}{Taxonomy of 19 RL research categories organized into five clusters: \textbf {Core Algorithms} (policy/value/model-based methods), \textbf {Learning Paradigms} (how agents acquire behavior), \textbf {Advanced Methods} (multi-agent, hierarchical, safe exploration), \textbf {Applications} (domain-specific implementations), and \textbf {Infrastructure} (frameworks, benchmarks, surveys). Arrows indicate foundational dependencies}{figure.caption.84}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.4}{\ignorespaces Value-based methods learn $Q(s,a)$ and derive policy via $\arg \max $; policy-based methods directly parameterize $\pi _\theta (a|s)$ and sample actions stochastically.}}{38}{figure.caption.85}\protected@file@percent }
\newlabel{fig:core_methods}{{3.4}{38}{Value-based methods learn $Q(s,a)$ and derive policy via $\arg \max $; policy-based methods directly parameterize $\pi _\theta (a|s)$ and sample actions stochastically}{figure.caption.85}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.5}{\ignorespaces Hierarchical RL: manager policy selects subgoals every $k$ steps; worker policy executes primitive actions to achieve them. Temporal abstraction reduces effective horizon.}}{39}{figure.caption.86}\protected@file@percent }
\newlabel{fig:hierarchical}{{3.5}{39}{Hierarchical RL: manager policy selects subgoals every $k$ steps; worker policy executes primitive actions to achieve them. Temporal abstraction reduces effective horizon}{figure.caption.86}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.6}{\ignorespaces Exploration via intrinsic motivation: curiosity rewards ($r_i$) supplement sparse external rewards ($r_e$), enabling learning in hard-exploration domains.}}{40}{figure.caption.87}\protected@file@percent }
\newlabel{fig:exploration}{{3.6}{40}{Exploration via intrinsic motivation: curiosity rewards ($r_i$) supplement sparse external rewards ($r_e$), enabling learning in hard-exploration domains}{figure.caption.87}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.7}{\ignorespaces Model-based RL loop: learn dynamics model from real experience, then use imagined rollouts for planning, cutting data requirements 10--100$\times $.}}{40}{figure.caption.88}\protected@file@percent }
\newlabel{fig:model_based}{{3.7}{40}{Model-based RL loop: learn dynamics model from real experience, then use imagined rollouts for planning, cutting data requirements 10--100$\times $}{figure.caption.88}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3.8}{\ignorespaces Meta-RL: learn initialization $\theta $ that enables fast adaptation to new tasks with few gradient steps. Outer loop optimizes ``learning to learn.''}}{41}{figure.caption.89}\protected@file@percent }
\newlabel{fig:meta_rl}{{3.8}{41}{Meta-RL: learn initialization $\theta $ that enables fast adaptation to new tasks with few gradient steps. Outer loop optimizes ``learning to learn.''}{figure.caption.89}{}}
