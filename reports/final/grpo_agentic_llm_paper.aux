\@writefile{toc}{\contentsline {section}{\numberline {5}Analysis}{6}{section.5}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.1}Capacity Threshold for GRPO}{6}{subsection.5.1}\protected@file@percent }
\newlabel{sec:capacity}{{5.1}{6}{Capacity Threshold for GRPO}{subsection.5.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Capacity threshold for GRPO on GSM8K. (a) Training-set reward trajectories: the 4B model (green) starts high and saturates, while 8B models (blue, 5 seeds) show noisy but productive learning. The 3B model (not shown; stays at $\sim $2\%) fails entirely. (b) Zero-loss vs.\ zero-reward step percentages reveal opposite failure modes: 3B's zero-loss stems from all-incorrect groups (stalled), while 4B's stems from all-correct groups (saturated).\relax }}{7}{figure.caption.8}\protected@file@percent }
\newlabel{fig:capacity}{{1}{7}{Capacity threshold for GRPO on GSM8K. (a) Training-set reward trajectories: the 4B model (green) starts high and saturates, while 8B models (blue, 5 seeds) show noisy but productive learning. The 3B model (not shown; stays at $\sim $2\%) fails entirely. (b) Zero-loss vs.\ zero-reward step percentages reveal opposite failure modes: 3B's zero-loss stems from all-incorrect groups (stalled), while 4B's stems from all-correct groups (saturated).\relax }{figure.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces GRPO training diagnostics on arithmetic (8B model, 25 steps). (a) Policy entropy collapses by $>$3 orders of magnitude, indicating convergence to a near-deterministic policy. (b) Group composition shifts from mostly mixed (gradient signal) to all-good (saturated, diminishing returns). (c) Reward rapidly approaches 1.0. These diagnostics were logged only for this task; comparable metrics for GSM8K/MATH remain a priority gap.\relax }}{7}{figure.caption.9}\protected@file@percent }
\newlabel{fig:diagnostics}{{2}{7}{GRPO training diagnostics on arithmetic (8B model, 25 steps). (a) Policy entropy collapses by $>$3 orders of magnitude, indicating convergence to a near-deterministic policy. (b) Group composition shifts from mostly mixed (gradient signal) to all-good (saturated, diminishing returns). (c) Reward rapidly approaches 1.0. These diagnostics were logged only for this task; comparable metrics for GSM8K/MATH remain a priority gap.\relax }{figure.caption.9}{}}
