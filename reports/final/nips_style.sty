% NeurIPS style file (simplified version for submission)
% Based on the official NeurIPS style

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{nips_style}[2026 NeurIPS Style]

% Page layout
% Use only core packages available in minimal TeX installs.
\RequirePackage[margin=1in]{geometry}
\RequirePackage{times}
\RequirePackage{color}
\RequirePackage{url}
\RequirePackage{latexsym}
\RequirePackage{amsmath,amssymb,mathtools}
\RequirePackage{booktabs}
\RequirePackage{microtype}

% For figures
\RequirePackage{graphicx}
\RequirePackage{caption}
\RequirePackage{subcaption}

% Bibliography
\RequirePackage{natbib}

% Hyperref
\RequirePackage{hyperref}
\hypersetup{
    colorlinks=true,
    linkcolor=blue,
    citecolor=blue,
    urlcolor=blue
}

% ===========================================================================
% Custom commands
% ===========================================================================
\def\beforereview{\special{papersize=\the\paperwidth,\the\paperheight}}
\def\endbeforereview{}

% Final mode
\DeclareOption{final}{\renewcommand\beforereview{}}
\DeclareOption{preprint}{\renewcommand\endbeforereview{}}

% Process options
\ProcessOptions\relax

\AtBeginDocument{%
  \setlength{\parindent}{0pt}%
  \setlength{\parskip}{0.35em}%
}

% ===========================================================================
% Page limits (NeurIPS style)
% ===========================================================================
% 9 pages content + references
% With preprint option, these limits are relaxed
\endinput
